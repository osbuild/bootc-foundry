#!/usr/bin/env python3
"""
Generate GitHub Actions matrix JSON and wrapper scripts from config.yaml.

Config: root key "images" (list of OS/image configs). Each image has:
  - id, containerfile (suffix for Containerfile.{containerfile}-{type}), pipeline
  - from_image, from_tag, arches, types
  - For pipeline=github: to_image, to_tag_prefix (writes to matrix JSON)
  - For pipeline=shell: no to_image/to_tag_prefix (matrix-ID.sh takes IMAGE:TAG_PREFIX as arg)

Outputs:
  - build-matrix.json, manifest-matrix.json (from pipeline=github only)
  - matrix-{id}.sh per pipeline=shell image only (arg: IMAGE:TAG_PREFIX; no caching)

Usage:
  ./generate-matrix [--config CONFIG] [--out-dir DIR]
"""

import argparse
import json
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    print("PyYAML required: pip install pyyaml", file=sys.stderr)
    sys.exit(1)


def load_config(path: Path) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def build_matrices(config: dict) -> tuple[list, list]:
    """Build matrices for pipeline=github only. Uses containerfile + '-' + type for Containerfile.XXX-type."""
    build_include = []
    manifest_include = []

    for img in config["images"]:
        if img.get("pipeline") != "github":
            continue
        from_image = img["from_image"]
        from_tag = str(img["from_tag"])
        to_image = img["to_image"]
        to_tag_prefix = str(img["to_tag_prefix"])
        arches = img["arches"]
        types = img["types"]
        cf_suffix = img["containerfile"]  # Containerfile.{containerfile}-{type}

        for t in types:
            containerfile = f"{cf_suffix}-{t}"
            to_tag = f"{to_tag_prefix}-{t}"
            for arch in arches:
                build_include.append({
                    "containerfile": containerfile,
                    "to_tag": to_tag,
                    "arch": arch,
                    "to_image": to_image,
                    "from_image": from_image,
                    "from_tag": from_tag,
                })

        arches_str = " ".join(arches)
        for t in types:
            tag = f"{to_tag_prefix}-{t}"
            manifest_include.append({
                "image": to_image,
                "arches": arches_str,
                "tag": tag,
            })

    return build_include, manifest_include


def shell_pipeline_images(config: dict) -> list:
    """Return list of image configs with pipeline=shell (for matrix-ID.sh scripts)."""
    return [img for img in config["images"] if img.get("pipeline") == "shell"]


def shell_quote(s: str) -> str:
    """Escape a string for use inside double quotes in shell."""
    return s.replace("\\", "\\\\").replace("$", "\\$").replace("`", "\\`").replace('"', '\\"')


def generate_build_id_sh(img: dict) -> str:
    """Generate matrix-{id}.sh for a shell-pipeline image. Takes one arg: image:tag_prefix. No caching."""
    img_id = img["id"]
    from_image = img["from_image"]
    from_tag = str(img["from_tag"])
    arches = img["arches"]
    types = img["types"]
    cf_suffix = img["containerfile"]

    lines = [
        "#!/usr/bin/env bash",
        "set -xeuo pipefail",
        "",
        "# Generated by generate-matrix from config.yaml - do not edit manually.",
        "# Usage: matrix-%s.sh IMAGE:TAG_PREFIX" % shell_quote(img_id),
        "# Example: matrix-%s.sh my-registry/my-image:my-tag" % shell_quote(img_id),
        "",
        'SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"',
        'cd "$SCRIPT_DIR"',
        "",
        "if [ $# -lt 1 ]; then",
        '  echo "Usage: matrix-%s.sh IMAGE:TAG_PREFIX" >&2' % shell_quote(img_id),
        '  echo "Example: matrix-%s.sh my-registry/my-image:my-tag" >&2' % shell_quote(img_id),
        "  exit 1",
        "fi",
        "",
        "ARG_IMAGE_TAG=\"$1\"",
        'TO_IMAGE="${ARG_IMAGE_TAG%:*}"',
        'TAG_PREFIX="${ARG_IMAGE_TAG##*:}"',
        "if [ \"$TO_IMAGE\" = \"$ARG_IMAGE_TAG\" ] || [ -z \"$TAG_PREFIX\" ]; then",
        '  echo "Error: argument must be IMAGE:TAG_PREFIX (e.g. my-registry/my-image:my-tag)" >&2',
        "  exit 1",
        "fi",
        "",
    ]
    for t in types:
        containerfile = f"{cf_suffix}-{t}"
        for arch in arches:
            lines.append(
                'export TO_IMAGE="$TO_IMAGE" TO_TAG="${TAG_PREFIX}-%s" ARCH="%s" CONTAINERFILE="%s" FROM_IMAGE="%s" FROM_TAG="%s"'
                % (shell_quote(t), shell_quote(arch), shell_quote(containerfile), shell_quote(from_image), shell_quote(from_tag))
            )
            lines.append("time ./build-and-push.sh")
            lines.append("")

    arches_str = " ".join(arches)
    for t in types:
        lines.append('export IMAGE="$TO_IMAGE" TAG="${TAG_PREFIX}-%s" ARCHES="%s"' % (shell_quote(t), shell_quote(arches_str)))
        lines.append("time ./generate-manifests.sh")
        lines.append("")

    return "\n".join(lines).rstrip() + "\n"


def main() -> None:
    root = Path(__file__).resolve().parent
    parser = argparse.ArgumentParser(description="Generate workflow matrices from config.yaml")
    parser.add_argument(
        "--config",
        type=Path,
        default=root / "config.yaml",
        help="Path to config YAML",
    )
    parser.add_argument(
        "--out-dir",
        type=Path,
        default=root / ".github" / "matrices",
        help="Directory to write matrix JSON files",
    )
    args = parser.parse_args()

    config = load_config(args.config)
    if "images" not in config:
        print("Config must have root key 'images' (list).", file=sys.stderr)
        sys.exit(1)

    build_include, manifest_include = build_matrices(config)
    shell_images = shell_pipeline_images(config)

    args.out_dir.mkdir(parents=True, exist_ok=True)

    build_path = args.out_dir / "build-matrix.json"
    manifest_path = args.out_dir / "manifest-matrix.json"

    with open(build_path, "w") as f:
        json.dump({"include": build_include}, f, indent=2)

    with open(manifest_path, "w") as f:
        json.dump({"include": manifest_include}, f, indent=2)

    print(f"Wrote {build_path} ({len(build_include)} entries)")
    print(f"Wrote {manifest_path} ({len(manifest_include)} entries)")

    for img in shell_images:
        script_name = f"matrix-{img['id']}.sh"
        script_path = root / script_name
        with open(script_path, "w") as f:
            f.write(generate_build_id_sh(img))
        script_path.chmod(0o755)
        print(f"Wrote {script_path}")


if __name__ == "__main__":
    main()
