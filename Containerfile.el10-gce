FROM quay.io/osbuild/centos-bootc

ARG CONTAINERFILE=Containerfile
COPY $CONTAINERFILE /root/Containerfile
COPY gce /root

COPY --chown=root:root --chmod=0644 gce/etc/yum.repos.d/google-cloud-el10.repo /etc/yum.repos.d/google-cloud-el10.repo

RUN dnf install -y \
	"@core" \
	"acpid" \
	"chrony" \
	"dnf-automatic" \
	"gce-disk-expand" \
	"google-compute-engine" \
	"google-osconfig-agent" \
	"grub2-tools" \
	"grub2-tools-minimal" \
	"langpacks-en" \
	"net-tools" \
	"python3" \
	"rng-tools" \
	"tar" \
	"timedatex" \
	"tuned" \
	"vim" && \
	dnf clean all

RUN echo 'kargs = ["biosdevname=0 scsi_mod.use_blk_mq=Y console=ttyS0,38400n8d"]' > /usr/lib/bootc/kargs.d/50-image-builder.toml

RUN systemctl enable \
	"dnf-automatic.timer" \
	"rngd" \
	"sshd" && \
	systemctl disable \
		"reboot.target" \
		"sshd-keygen@"
