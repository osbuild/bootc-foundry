# vim: set ft=dockerfile:
# -*- mode: dockerfile-mode -*-
# code: language=dockerfile insertSpaces=true tabSize=4

FROM registry.redhat.io/rhel10/rhel-bootc:latest

ARG TARGETARCH

#
# Extra packages:
#
# @guest-agents: Guest agents for QEMU and libvirt.
# cloud-init: cloud instance configuration tool
#
RUN dnf install -y \
    @guest-agents \
    cloud-init \
    && dnf clean all

# Copy common configuration
#COPY qcow2/etc/ /etc/
#COPY qcow2/usr/ /usr/

# Copy architecture-specific configuration
COPY qcow2-${TARGETARCH}/usr/ /usr/

COPY rhel-10-qcow2 /root/Containerfile
